# Copy to .env and fill in from your Supabase project:
# Dashboard > Project Settings > API
#
# Both names must start with EXPO_PUBLIC_ or the Expo bundler will not inline
# them, and the app will start up thinking it has no backend.
#
# Leaving these as they are, or deleting the file, is a supported state. Garage
# then runs exactly as it always has: everything on the phone, no accounts, no
# sync, no sign in screen. See src/lib/supabase.ts.
#
# The anon key is meant to ship inside the app. It grants nothing on its own:
# every table has row level security, so the key can only ever read and write
# rows the signed in account is allowed to touch.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
